+async def _looks_like_no_result(page):
+    try:
+        body_text = (await page.locator("body").inner_text()).lower()
+    except Exception:
+        return False
+
+    for pattern in NO_RESULT_PATTERNS:
+        if re.search(pattern, body_text, re.IGNORECASE):
+            return True
+    return False
